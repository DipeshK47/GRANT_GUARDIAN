{
  "name": "grant-guardian",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:local",
    "dev:local": "node scripts/dev-local.mjs",
    "dev:orchestrator": "npm run dev --workspace @grant-guardian/orchestrator",
    "dev:web": "npm run dev --workspace @grant-guardian/web",
    "build": "npm run build --workspace @grant-guardian/shared && npm run build --workspace @grant-guardian/orchestrator && npm run build --workspace @grant-guardian/web",
    "typecheck": "npm run typecheck --workspace @grant-guardian/shared && npm run typecheck --workspace @grant-guardian/orchestrator && npm run typecheck --workspace @grant-guardian/web",
    "lint": "npm run lint --workspace @grant-guardian/shared && npm run lint --workspace @grant-guardian/orchestrator && npm run lint --workspace @grant-guardian/web",
    "test": "npm run test --workspace @grant-guardian/orchestrator",
    "db:generate": "node node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node scripts/db-migrate.mjs",
    "bootstrap:notion": "node node_modules/tsx/dist/cli.mjs scripts/bootstrap-notion.ts",
    "organization:save": "node --import tsx scripts/save-organization-profile.ts",
    "onboarding:status": "node --import tsx scripts/onboarding-status.ts",
    "submittable:install-browser": "node node_modules/playwright/cli.js install chromium",
    "submittable:save-session": "node node_modules/tsx/dist/cli.mjs scripts/save-submittable-session.ts",
    "test:pdf-ocr": "node --import tsx scripts/test-pdf-ocr.ts",
    "upload:document": "node --import tsx scripts/upload-document.ts",
    "discover:portal": "node --import tsx scripts/discover-portal.ts",
    "portal:readiness": "node --import tsx scripts/check-portal-readiness.ts",
    "seed:demo": "node node_modules/tsx/dist/cli.mjs scripts/seed-demo.ts",
    "enrich:funder": "node node_modules/tsx/dist/cli.mjs scripts/enrich-funder.ts",
    "parse:funder-filings": "node node_modules/tsx/dist/cli.mjs scripts/parse-funder-filings.ts",
    "contrast:funders": "node --import tsx scripts/contrast-funders.ts",
    "analyze:opportunity": "node node_modules/tsx/dist/cli.mjs scripts/analyze-opportunity.ts",
    "draft:opportunity": "node node_modules/tsx/dist/cli.mjs scripts/draft-opportunity.ts",
    "review:opportunity": "node node_modules/tsx/dist/cli.mjs scripts/review-opportunity.ts",
    "review:respond": "node node_modules/tsx/dist/cli.mjs scripts/respond-review.ts",
    "assemble:submission": "node node_modules/tsx/dist/cli.mjs scripts/assemble-submission.ts",
    "stage:upload-artifacts": "node node_modules/tsx/dist/cli.mjs scripts/stage-upload-artifacts.ts",
    "prepare:form-fill": "node node_modules/tsx/dist/cli.mjs scripts/prepare-form-fill.ts",
    "show:portal-profiles": "node node_modules/tsx/dist/cli.mjs scripts/show-portal-profiles.ts",
    "launch:submission-autopilot": "node node_modules/tsx/dist/cli.mjs scripts/launch-submission-autopilot.ts",
    "authorize:final-submit": "node node_modules/tsx/dist/cli.mjs scripts/authorize-final-submit.ts",
    "activate:reporting": "node --import tsx scripts/activate-reporting.ts",
    "show:reporting": "node --import tsx scripts/show-reporting.ts",
    "update:reporting": "node --import tsx scripts/update-reporting-status.ts",
    "record:lesson": "node --import tsx scripts/record-lesson.ts",
    "show:lessons": "node --import tsx scripts/show-lessons.ts",
    "update:lesson": "node --import tsx scripts/update-lesson.ts",
    "run:opportunity": "node node_modules/tsx/dist/cli.mjs scripts/run-opportunity.ts",
    "run:demo": "node node_modules/tsx/dist/cli.mjs scripts/run-demo.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.13.10",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
